NODE_ENV=development
PORT=3001

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=password
DB_NAME=realestate_db

# ── JWT ───────────────────────────────────────────────────────────────────────
# Access token: short-lived (15m in production)
JWT_SECRET=CHANGE-ME-use-openssl-rand-base64-64
JWT_EXPIRES_IN=15m

# Refresh token: long-lived (7d), separate secret
JWT_REFRESH_SECRET=CHANGE-ME-different-from-JWT_SECRET-openssl-rand-base64-64
JWT_REFRESH_EXPIRES_IN=7d

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3001
# Comma-separated list of allowed CORS origins
FRONTEND_URL=http://localhost:3000

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=5242880

# ── Field-Level Encryption (AES-256-GCM for PII: email, phone, lead data) ────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
FIELD_ENCRYPTION_KEY=CHANGE-ME-random-48-bytes-base64
FIELD_ENCRYPTION_SALT=CHANGE-ME-random-salt

# ── CDN Signed URLs ───────────────────────────────────────────────────────────
CDN_SIGNING_SECRET=CHANGE-ME-cdn-signing-secret
CDN_BASE_URL=https://cdn.think4buysale.com
CDN_URL_TTL_SECONDS=3600

# ── Internal Service Request Signing (HMAC) ───────────────────────────────────
# Set ENABLE_REQUEST_SIGNING=true to enforce HMAC validation on /internal/* routes
ENABLE_REQUEST_SIGNING=false
INTERNAL_API_KEY=CHANGE-ME-internal-api-key
INTERNAL_API_SECRET=CHANGE-ME-internal-api-secret

# ── Rate Limiting ─────────────────────────────────────────────────────────────
# These are the defaults; individual endpoints can override via @Throttle()
# Global default: 100 req / 60s per IP (see app.module.ts ThrottlerModule)

# ── Payment System ────────────────────────────────────────────────────────────
# Master switch: false = token-based system (existing flow, no gateway needed)
#                true  = real money payments via active gateway (requires gateway setup in admin)
PAYMENT_ENABLED=false

# ── Redis (BullMQ queues: payment, image-processing, video-processing) ────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ── Database Read Replica (MySQL / Aurora) ────────────────────────────────────
# Set ENABLE_DB_REPLICA=true to route SELECT queries to the read replica.
# All writes continue to the primary (DB_HOST).
ENABLE_DB_REPLICA=false
DB_REPLICA_HOST=
DB_REPLICA_PORT=3306
DB_REPLICA_USERNAME=
DB_REPLICA_PASSWORD=

# ── Payment Gateway Credentials (configure via Admin Panel, NOT .env) ─────────
# Gateway credentials are stored ENCRYPTED in the database via the Admin Panel.
# The FIELD_ENCRYPTION_KEY above is used to AES-256 encrypt gateway configs.
# DO NOT store raw gateway keys here in production — use the admin UI instead.
#
# To add a gateway:
#   POST /api/v1/admin/payment/gateways
#   { "name": "razorpay", "displayName": "Razorpay Production",
#     "config": { "keyId": "rzp_live_xxx", "keySecret": "yyy", "webhookSecret": "zzz" } }
#
# Razorpay webhook URL: https://yourdomain.com/api/v1/payment/webhook/razorpay
# Stripe webhook URL:   https://yourdomain.com/api/v1/payment/webhook/stripe
