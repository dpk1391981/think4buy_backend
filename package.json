{
  "name": "realestate-backend",
  "version": "1.0.0",
  "description": "Real Estate Platform Backend - NestJS",
  "author": "",
  "private": true,
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "seed": "node -r dotenv/config -r ts-node/register src/database/seeds/seed.ts",
    "seed:agency": "node -r dotenv/config -r ts-node/register src/database/seeds/seed-agency.ts",
    "seed:leads": "node -r dotenv/config -r ts-node/register src/database/seeds/seed-leads.ts",
    "seed:articles": "node -r dotenv/config -r ts-node/register src/database/seeds/seed-articles.ts",
    "seed:premium-slots": "node -r dotenv/config -r ts-node/register src/database/seeds/reseed-premium-slots.ts",
    "seed:footer-links": "node -r dotenv/config -r ts-node/register src/database/seeds/reseed-footer-links.ts",
    "seed:messaging": "node -r dotenv/config -r ts-node/register src/database/seeds/seed-messaging.ts",
    "correct-locations": "node -r dotenv/config -r ts-node/register src/database/seeds/correct-locations.ts",
    "correct-locations:dry": "DRY_RUN=true node -r dotenv/config -r ts-node/register src/database/seeds/correct-locations.ts",
    "correct-locations:geocode": "GEOCODE=true node -r dotenv/config -r ts-node/register src/database/seeds/correct-locations.ts",
    "seed:locations-xlsx": "node -r dotenv/config -r ts-node/register src/database/seeds/seed-locations-xlsx.ts",
    "seed:locations-xlsx:dry": "DRY_RUN=true node -r dotenv/config -r ts-node/register src/database/seeds/seed-locations-xlsx.ts",
    "seed:locations-xlsx:geocode": "GEOCODE=true node -r dotenv/config -r ts-node/register src/database/seeds/seed-locations-xlsx.ts",
    "seed:locations-xlsx:geocode-force": "GEOCODE=true FORCE_GEO=true node -r dotenv/config -r ts-node/register src/database/seeds/seed-locations-xlsx.ts"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.1.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^7.1.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^10.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/nodemailer": "^7.0.11",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.71.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.0",
    "nodemailer": "^8.0.2",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "slugify": "^1.6.6",
    "typeorm": "^0.3.17",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/bcryptjs": "^2.4.2",
    "@types/express": "^4.17.17",
    "@types/multer": "^1.4.7",
    "@types/node": "^20.3.1",
    "@types/passport-jwt": "^3.0.9",
    "@types/passport-local": "^1.0.35",
    "@types/sharp": "^0.31.1",
    "@types/uuid": "^9.0.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.3"
  }
}
