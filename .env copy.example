## =============================================================================
## Think4BuySale Backend — Environment Variables
## =============================================================================
## Copy this file:
##   Mac/Linux : cp .env.example .env
##   Windows   : copy .env.example .env
##
## For LOCAL DEV: defaults below work with docker-compose.dev.yml (MySQL + Redis)
## For PRODUCTION: deploy.sh generates all values automatically
## =============================================================================

# ── Environment ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
BIND_HOST=0.0.0.0        # dev: 0.0.0.0  |  prod: 127.0.0.1 (or set by deploy.sh)

# ── Database ──────────────────────────────────────────────────────────────────
# Dev defaults match docker-compose.dev.yml
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=1391981
DB_NAME=realestate_db

# ── JWT ───────────────────────────────────────────────────────────────────────
# Dev: any string works | Prod: generate with: openssl rand -base64 64
JWT_SECRET=dev-jwt-secret-replace-in-production
JWT_EXPIRES_IN=7d

JWT_REFRESH_SECRET=dev-refresh-secret-replace-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ── App URLs ──────────────────────────────────────────────────────────────────
APP_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000  # comma-separated for multiple origins

# ── Redis ─────────────────────────────────────────────────────────────────────
# Dev defaults match docker-compose.dev.yml (no password)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://localhost:6379/0  # used by ioredis (bot detection)

# ── File Upload ───────────────────────────────────────────────────────────────
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760    # 10 MB

# ── Field-Level Encryption (PII: email, phone, lead data) ────────────────────
# Dev: any 32+ char string | Prod: generate with openssl rand -base64 48
FIELD_ENCRYPTION_KEY=dev-encryption-key-min-32-characters
FIELD_ENCRYPTION_SALT=dev-salt-value

# ── CDN / Signed URLs ─────────────────────────────────────────────────────────
CDN_SIGNING_SECRET=dev-cdn-secret
CDN_BASE_URL=http://localhost:3001
CDN_URL_TTL_SECONDS=3600

# ── BFF Security ──────────────────────────────────────────────────────────────
# Dev: ENABLE_BFF_GUARD=false (allows direct Swagger/Postman testing)
# Prod: ENABLE_BFF_GUARD=true + strong secret (set by deploy.sh)
ENABLE_BFF_GUARD=false
BFF_INTERNAL_SECRET=dev-bff-secret

# Prod only: openssl rand -base64 32
ENABLE_REQUEST_SIGNING=false
INTERNAL_API_KEY=dev-api-key
INTERNAL_API_SECRET=dev-api-secret

# ── Cache Invalidation ────────────────────────────────────────────────────────
CACHE_INVALIDATE_SECRET=dev-cache-secret
FRONTEND_INTERNAL_URL=http://localhost:3000

# ── Payment ───────────────────────────────────────────────────────────────────
PAYMENT_ENABLED=false     # true only after gateway configured in admin panel

# ── DB Read Replica ───────────────────────────────────────────────────────────
ENABLE_DB_REPLICA=false
DB_REPLICA_HOST=
DB_REPLICA_PORT=3306
DB_REPLICA_USERNAME=
DB_REPLICA_PASSWORD=

# ── Cloudflare (prod only) ────────────────────────────────────────────────────
CF_ZONE_ID=
CF_API_TOKEN=
